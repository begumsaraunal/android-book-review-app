<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/card_bg"
    android:foreground="?attr/selectableItemBackgroundBorderless"
    android:clickable="true"
    android:focusable="true"
    app:cardUseCompatPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <FrameLayout
            android:id="@+id/recycler_row_coverContainer"
            android:layout_width="104dp"
            android:layout_height="156dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:letterSpacing="0.05"
            android:background="@drawable/rounded_cover_bg"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/recycler_row_imageView"
                android:layout_width="match_parent"
                app:shapeAppearanceOverlay="@style/ImageCornerStyle"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:elevation="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/recycler_row_letter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:visibility="gone"/>

        </FrameLayout>

        <TextView
            android:id="@+id/recycler_row_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:alpha="0.7"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:textStyle="italic"
            app:layout_constraintEnd_toStartOf="@id/recycler_row_coverContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/recycler_row_book_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/recycler_row_username"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/recycler_row_coverContainer"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/recycler_row_book_author"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/textSecondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/recycler_row_book_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/recycler_row_coverContainer"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/recyclerRowLikes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/_0_likes"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/recycler_row_book_context"
            app:layout_constraintVertical_bias="1.0" />

        <TextView
            android:id="@+id/recycler_row_book_context"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/content"
            android:maxLines="3"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/recycler_row_book_author"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/recycler_row_coverContainer"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="6dp"/>



    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
